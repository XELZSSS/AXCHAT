{
  "name": "axchat",
  "description": "AXCHAT desktop chat client",
  "author": "AXCHAT",
  "license": "GPL-3.0-only",
  "private": true,
  "version": "1.1.0",
  "type": "module",
  "main": "apps/main/main.cjs",
  "scripts": {
    "dev": "vite",
    "proxy:llm": "node apps/server/llm-proxy.mjs",
    "dev:all": "concurrently -k -n proxy,dev -c yellow,cyan \"npm run proxy:llm\" \"npm run dev\"",
    "electron:dev": "concurrently -k -n dev,electron -c cyan,magenta \"npm run dev\" \"wait-on http://localhost:3000 && set VITE_DEV_SERVER_URL=http://localhost:3000 && node scripts/run-electron.cjs .\"",
    "build": "vite build",
    "electron:build:win": "npm run build && set \"ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/\" && set \"ELECTRON_BUILDER_BINARIES_MIRROR=https://npmmirror.com/mirrors/electron-builder-binaries/\" && set \"ELECTRON_CACHE=.cache\\electron\" && set \"ELECTRON_BUILDER_CACHE=.cache\\electron-builder\" && electron-builder --win --x64",
    "preview": "vite preview",
    "models:sync:official": "node scripts/sync-official-model-catalogs.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "audit": "set \"npm_config_registry=https://registry.npmjs.org/\" && npm audit",
    "format": "prettier . --write",
    "format:check": "prettier . --check"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fastify/cors": "^11.2.0",
    "@fastify/http-proxy": "^11.4.1",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@google/genai": "^1.45.0",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "better-sqlite3": "^12.6.2",
    "fastify": "^5.8.2",
    "openai": "^6.27.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^25.5.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitejs/plugin-react": "^6.0.0",
    "concurrently": "^9.2.1",
    "electron": "^41.0.1",
    "electron-builder": "^26.8.2",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "wait-on": "^9.0.4"
  },
  "overrides": {
    "node-gyp": "^12.2.0",
    "tar": "^7.5.11"
  },
  "build": {
    "appId": "com.axchat.app",
    "productName": "AXCHAT",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "apps/main/**",
      "apps/shared/**",
      "assets/icons/**",
      "scripts/**",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "apps/server",
        "to": "server"
      },
      {
        "from": "apps/shared",
        "to": "shared"
      }
    ],
    "win": {
      "executableName": "AXCHAT",
      "icon": "assets/icons/app.ico",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "installerIcon": "assets/icons/app.ico",
      "uninstallerIcon": "assets/icons/app.ico",
      "include": "build/installer.nsh",
      "oneClick": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "XELZSSS",
        "repo": "AXCHAT"
      }
    ]
  }
}
